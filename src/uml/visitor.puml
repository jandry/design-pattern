@startuml Visitor

interface Visitor {
    + void visit(Visitable)
    + void visit(Gras)
    + void visit(Liste)
    + void visit(Titre)
}

class HtmlVisitor

Visitor <|.. HtmlVisitor

interface Visitable {
    + void accept(Visitor)
}

class Titre
class Gras
class Liste

class ElementTexte {
    - texte : String
    + getTexte(): String
    + {abstract} getHtml(): String
}

Visitable <|.. ElementTexte

ElementTexte <|-- Liste
ElementTexte <|-- Titre
ElementTexte <|-- Gras


@enduml